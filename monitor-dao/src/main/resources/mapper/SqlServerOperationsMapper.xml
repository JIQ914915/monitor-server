<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lzzh.monitor.dao.mapper.SqlServerOperationsMapper">
 <select id="countRestoreDrills" resultType="long">SELECT count(*) FROM sqlserver_restore_drill WHERE instance_id=#{instanceId}</select>
 <select id="selectRestoreDrills" resultType="java.util.Map">
  SELECT id,backup_reference,started_at,finished_at,status,validation_result,rto_seconds,owner_name,notes,created_at
  FROM sqlserver_restore_drill WHERE instance_id=#{instanceId} ORDER BY started_at DESC LIMIT #{limit} OFFSET #{offset}
 </select>
 <insert id="insertRestoreDrill" useGeneratedKeys="true" keyProperty="drill.id">
  INSERT INTO sqlserver_restore_drill(instance_id,backup_reference,started_at,finished_at,status,validation_result,rto_seconds,owner_name,notes,created_by)
  VALUES(#{drill.instanceId},#{drill.backupReference},#{drill.startedAt},#{drill.finishedAt},#{drill.status},#{drill.validationResult},#{drill.rtoSeconds},#{drill.ownerName},#{drill.notes},#{drill.createdBy})
 </insert>
</mapper>
