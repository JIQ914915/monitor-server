<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lzzh.monitor.dao.mapper.DbInstanceMapper">
    <select id="selectByShard" resultType="com.lzzh.monitor.dao.entity.DbInstance">
        SELECT * FROM db_instance
        WHERE ABS(HASHTEXT(instance_code)) % #{shardTotal} = #{shardIndex}
    </select>

    <select id="selectIdsByGroupIds" resultType="long">
        SELECT DISTINCT id FROM db_instance WHERE
        <foreach collection="groupIds" item="gid" open="(" separator=" OR " close=")">
            group_ids @> CONCAT('[', #{gid}, ']')::jsonb
        </foreach>
    </select>
</mapper>
