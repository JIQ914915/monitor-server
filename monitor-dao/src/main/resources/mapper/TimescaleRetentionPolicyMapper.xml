<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lzzh.monitor.dao.mapper.TimescaleRetentionPolicyMapper">
    <select id="addRetentionPolicy" resultType="java.lang.Object">
        SELECT add_retention_policy(CAST(#{table} AS regclass),
               make_interval(days => #{retentionDays}), if_not_exists => true)
    </select>
</mapper>
